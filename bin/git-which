#!/usr/bin/env bash

# Example
# $ git which-alias amd
# git commit --ammaned

# Example of $ git config list
# alias.a=add
# alias.wtp=worktree prune
# alias.emp=commit --allow-empty
if [ "$1" == "" ]; then
    echo "USAGE"
    echo "git which <git alias command>"
    echo
    echo "EXAMPLE"
    echo "git which cb"
    exit 1
fi

if [ "$1" == "fzf" ]; then
    git config list | grep alias | fzf
else
    git config list | grep alias | grep "alias\.$1="
fi
